# ── OmniBridge environment ──────────────────────────────────────────────────
# Copy this file to `.env` (or `.env.local`) and fill in real values.
#
# Keys WITHOUT the `VITE_` prefix stay server-side only (read by the
# translate proxy at api/translate.ts). Keys WITH the prefix are bundled
# into the browser JS, so never put secrets there.

# Supabase (optional — omit to run in local-only Dexie mode)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only Supabase credentials — used by /api/subscribe and /api/notify to
# persist push subscriptions across Vercel serverless cold starts. Never
# prefix with VITE_ (would leak to the browser bundle). SUPABASE_URL can be
# the same value as VITE_SUPABASE_URL above. The service role key is in the
# Supabase dashboard under Project Settings → API → "service_role" (secret).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Server-side translation keys ──────────────────────────────────────────
# At least one is needed for the translate proxy. If both are missing the
# app runs in Slovak-only mode and offline semantic search still works.

# Groq (free, very fast, primary if set) — https://console.groq.com/keys
GROQ_API_KEY=

# Gemini 1.5 Flash (fallback) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Web Push (notifications when neighbours reply) ────────────────────────
# Generate a fresh keypair with:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# Then set BOTH VAPID_PUBLIC_KEY and VITE_VAPID_PUBLIC_KEY to the public value
# (the VITE_ one is bundled into the browser so the client can subscribe), and
# VAPID_PRIVATE_KEY to the private value (server-only — signs push messages).
VITE_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
